{
  "name": "monorepo-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm run -r --parallel dev",
    "test": "vitest run",
    "test:dev": "vitest",
    "lint": "turbo run lint",
    "release": "changeset",
    "publish-packages": "turbo run build lint test && changeset version && changeset publish",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "commit",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/prompt-cli": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/commitlint-config": "^3.0.1",
    "@icebreakers/eslint-config": "^5.0.1",
    "@icebreakers/monorepo": "^4.0.8",
    "@icebreakers/stylelint-config": "^4.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "~4.1.6",
    "@vue/tsconfig": "^0.9.1",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "defu": "^6.1.7",
    "es-toolkit": "^1.46.1",
    "eslint": "^10.4.0",
    "execa": "^9.6.1",
    "fdir": "^6.5.0",
    "fs-extra": "^11.3.5",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "postcss": "^8.5.14",
    "rimraf": "^6.1.3",
    "stylelint": "^17.11.1",
    "tailwindcss": "^4.3.0",
    "tsdown": "0.22.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "turbo": "^2.9.14",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitepress": "^1.6.4",
    "vitest": "~4.1.6",
    "vue-tsc": "^3.2.9",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "vue-demi"
    ]
  }
}
